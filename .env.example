# CWSandbox Client - Integration Test Credentials
# Copy to .env and uncomment the auth option you want to use.
# .env is gitignored; .env.example is committed for documentation.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your credentials
#   uv run pytest tests/integration/ -v

# =============================================================================
# Required: CWSandbox API Key
# =============================================================================
# CWSANDBOX_API_KEY=your-cwsandbox-api-key

# =============================================================================
# Optional: W&B API key for live metrics verification in
# tests/integration/cwsandbox/test_wandb.py
# =============================================================================
# WANDB_API_KEY=your-wandb-api-key

# =============================================================================
# Optional: API Endpoint Override
# =============================================================================
# CWSANDBOX_BASE_URL=https://atc.cw-sandbox.com
